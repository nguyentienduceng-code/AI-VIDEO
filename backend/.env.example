
# ─────────────────────────────────────────
# AI VIDEO MAKER — Backend Environment
# ─────────────────────────────────────────
# Lấy API Key miễn phí tại: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Cổng chạy Backend (mặc định: 8000)
PORT=8000

# Thư mục lưu video xuất ra
OUTPUT_DIR=assets/output

# Giọng đọc mặc định (Edge TTS)
# Nữ: vi-VN-HoaiMyNeural | Nam: vi-VN-NamMinhNeural
TTS_VOICE=vi-VN-HoaiMyNeural
